DASHSCOPE_API_KEY=your_dashscope_api_key
# langextract 元数据抽取模型（可选，默认 qwen3.7-plus）
# METADATA_MODEL_ID=qwen3.7-plus
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 标准审核专用模型，暂未使用embedding模型，此处为占位（覆盖 config.yaml.standard_review.judge_* / embedding_*）
# DASHSCOPE_JUDGE_MODEL=qwen3.7-plus
# DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# HTTP 产物下载 API 前缀（登记后返回 /api/threads/{thread_id}/artifacts/{artifact_id}/download）
# STANDARD_DOC_ARTIFACT_API_BASE=http://127.0.0.1:8080
# SSE/API 是否向前端暴露 host_path（本地调试可设 1）
# STANDARD_DOC_EXPOSE_HOST_PATH=0
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=standard-document-assistant

# MinerU local 使用自建 /file_parse；precise 使用 mineru.net 精准解析 API。
MINERU_API_MODE=local
MINERU_API_BASE_URL=http://127.0.0.1:18001
# MINERU_API_MODE=precise
# MINERU_API_TOKEN=your_mineru_token  # 注意：官网API Token有效期改为90天，请及时更新。
# MINERU_PRECISE_BASE_URL=https://mineru.net
# MINERU_PRECISE_MODEL_VERSION=vlm
# MINERU_PRECISE_POLL_INTERVAL=3
# MINERU_PRECISE_POLL_TIMEOUT=600
# MINERU_PRECISE_EXTRA_FORMATS=docx,html
MINERU_REQUEST_TIMEOUT=600
MINERU_MAX_PDF_SIZE_MB=100

STANDARD_DOC_ENABLE_WORKSPACE_BACKEND=1
STANDARD_DOC_ENABLE_LOCAL_SKILLS_BACKEND=1

# langgraph dev / Studio 默认关闭 HITL（子图 resume 易传错格式导致 TypeError）。
# 生产或自建 API 审批流可设 STANDARD_DOC_ENABLE_HITL=1
# STANDARD_DOC_ENABLE_HITL=1
